/* ===========================
   NYABUTO MOSES BRIAN
   QA PORTFOLIO 
=========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    scroll-behavior:smooth;
}

body{
    font-family:Arial, Helvetica, sans-serif;
    background:#0D1117;
    color:#F0F6FC;
    line-height:1.7;
}

/* Navigation */

.navbar{
    position:sticky;
    top:0;
    width:100%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 8%;
    background:rgba(13,17,23,.95);
    backdrop-filter:blur(10px);
    border-bottom:1px solid #30363d;
    z-index:1000;
}

.logo{
    color:#58A6FF;
    font-size:28px;
    font-weight:bold;
}

.nav-links{
    display:flex;
    list-style:none;
    gap:25px;
}

.nav-links a{
    text-decoration:none;
    color:#F0F6FC;
    transition:.3s;
}

.nav-links a:hover{
    color:#58A6FF;
}

/* Hero */

.hero{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    text-align:center;
    padding:50px 20px;
}

.profile-photo{
    width:220px;
    height:220px;
    border-radius:50%;
    object-fit:cover;
    border:6px solid #58A6FF;
    box-shadow:0 0 30px rgba(88,166,255,.4);
    margin-bottom:25px;
    transition:.4s;
}

.profile-photo:hover{
    transform:scale(1.05);
}

.hero h1{
    font-size:3.2rem;
    margin-bottom:10px;
}

.job-title{
    color:#58A6FF;
    margin-bottom:20px;
}

.hero-text{
    max-width:700px;
    color:#8B949E;
    margin-bottom:35px;
    font-size:1.1rem;
}

.buttons{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
    justify-content:center;
}

.btn{
    background:#238636;
    color:white;
    text-decoration:none;
    padding:14px 28px;
    border-radius:50px;
    transition:.3s;
    font-weight:bold;
}

.btn:hover{
    background:#2EA043;
    transform:translateY(-4px);
}

/* ===================================
   SECTIONS
=================================== */

section{
    width:90%;
    max-width:1200px;
    margin:90px auto;
}

section h2{
    text-align:center;
    font-size:2.3rem;
    color:#58A6FF;
    margin-bottom:50px;
    position:relative;
}

section h2::after{
    content:"";
    width:80px;
    height:4px;
    background:#58A6FF;
    display:block;
    margin:12px auto;
    border-radius:10px;
}

/* ===================================
   CARDS
=================================== */

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:25px;
}

.card{
    background:#161B22;
    border:1px solid #30363D;
    border-radius:18px;
    padding:30px;
    transition:all .35s ease;
    cursor:pointer;
}

.card:hover{
    transform:translateY(-10px);
    border-color:#58A6FF;
    box-shadow:0 15px 35px rgba(88,166,255,.18);
}

.card h3{
    color:#58A6FF;
    margin-bottom:15px;
    font-size:1.3rem;
}

.card p{
    color:#C9D1D9;
}

/* ===================================
   DASHBOARD
=================================== */

#dashboard .card{
    text-align:center;
}

#dashboard h3{
    font-size:2.6rem;
    color:#58A6FF;
    margin-bottom:10px;
}

#dashboard p{
    font-size:1rem;
    color:#8B949E;
}

/* ===================================
   ABOUT
=================================== */

#about p{
    max-width:900px;
    margin:auto;
    text-align:center;
    color:#C9D1D9;
    font-size:1.1rem;
}

/* ===================================
   SKILLS
=================================== */

#skills .card{
    text-align:center;
}

#skills .card:hover{
    background:#1C2128;
}

/* ===================================
   PROJECTS
=================================== */

#projects .card{
    display:flex;
    flex-direction:column;
    justify-content:space-between;
}

#projects .btn{
    margin-top:20px;
    display:inline-block;
    text-align:center;
}

/* ===================================
   BUTTON IMPROVEMENT
=================================== */

.btn{
    box-shadow:0 10px 20px rgba(35,134,54,.25);
}

.btn:hover{
    box-shadow:0 15px 30px rgba(35,134,54,.45);
}
