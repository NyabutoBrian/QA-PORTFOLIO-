*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    scroll-behavior:smooth;
}

body{
    font-family:Arial, Helvetica, sans-serif;
    background:#0D1117;
    color:#F0F6FC;
    line-height:1.7;
}

/* Navigation */

.navbar{
    position:sticky;
    top:0;
    width:100%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 8%;
    background:rgba(13,17,23,.95);
    backdrop-filter:blur(10px);
    border-bottom:1px solid #30363d;
    z-index:1000;
}

.logo{
    color:#58A6FF;
    font-size:28px;
    font-weight:bold;
}

.nav-links{
    display:flex;
    list-style:none;
    gap:25px;
}

.nav-links a{
    text-decoration:none;
    color:#F0F6FC;
    transition:.3s;
}

.nav-links a:hover{
    color:#58A6FF;
}

/* Hero */

.hero{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    text-align:center;
    padding:50px 20px;
}

.profile-photo{
    width:220px;
    height:220px;
    border-radius:50%;
    object-fit:cover;
    border:6px solid #58A6FF;
    box-shadow:0 0 30px rgba(88,166,255,.4);
    margin-bottom:25px;
    transition:.4s;
}

.profile-photo:hover{
    transform:scale(1.05);
}

.hero h1{
    font-size:3.2rem;
    margin-bottom:10px;
}

.job-title{
    color:#58A6FF;
    margin-bottom:20px;
}

.hero-text{
    max-width:700px;
    color:#8B949E;
    margin-bottom:35px;
    font-size:1.1rem;
}

.buttons{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
    justify-content:center;
}

.btn{
    background:#238636;
    color:white;
    text-decoration:none;
    padding:14px 28px;
    border-radius:50px;
    transition:.3s;
    font-weight:bold;
}

.btn:hover{
    background:#2EA043;
    transform:translateY(-4px);
}
